import QtQuick
import QtQuick.Controls
import QtQuick.Layouts
import QtQuick.Dialogs
import org.kde.kirigami as Kirigami
import Kreate 1.0

Kirigami.ApplicationWindow {
    id: root
    width: 800
    height: 600
    visible: true
    title: i18n("Kreate – Color Editor")

    ColorSchemeBuilder {
        id: scheme
    }

    pageStack.initialPage: Kirigami.ScrollablePage {
        id: editorPage
        title: i18n("Color Editor")

        ColumnLayout {
            anchors.fill: parent
            spacing: Kirigami.Units.largeSpacing

            Label {
                text: i18n("Theme Name:")
            }

            TextField {
                text: scheme.themeName
                onTextChanged: scheme.setThemeName(text)
                Layout.fillWidth: true
            }

            Rectangle {
                id: colorSample
                Layout.fillWidth: true
                height: 80
                radius: 8
                border.color: Kirigami.Theme.textColor
                color: scheme.color("Colors:Window", "BackgroundNormal")
            }

            Button {
                text: i18n("Pick Window Background")
                onClicked: colorDialog.open()
            }

            ColorDialog {
                id: colorDialog
                onAccepted: {
                    scheme.setColor("Colors:Window", "BackgroundNormal", colorDialog.color)
                }
            }

            Button {
                text: i18n("Save .colors File")
                onClicked: scheme.saveColorsFile(Qt.resolvedUrl("theme.colors"))
            }
        }
    }
}
